# Copy to /etc/business-analysis-market/market-analysis.env and set mode 0640.
# Never commit real tokens or paste them into deployment logs.
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-pro[1m]
MARKET_ANALYSIS_MODEL=deepseek-v4-pro[1m]
MARKET_ANALYSIS_MAX_TURNS=80
MARKET_ANALYSIS_MAX_BUDGET_USD=8
MARKET_ANALYSIS_TIMEOUT_SECONDS=3600
MARKET_ANALYSIS_SOURCE_TIMEOUT_SECONDS=25
MARKET_ANALYSIS_SOURCE_MAX_BYTES=33554432
MARKET_ANALYSIS_BUSINESS_YEAR=2026
CLAUDE_CODE_EFFORT_LEVEL=max
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
API_TIMEOUT_MS=3000000
AI_READONLY_TOKEN=

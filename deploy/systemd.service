[Unit]
Description=Business Analysis Dashboard API
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/business-analysis/backend
Environment="PATH=/opt/business-analysis/backend/venv/bin"
Environment="APP_ENV=production"
ExecStart=/opt/business-analysis/backend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 45679
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
